import os
import re
import subprocess
from pathlib import Path
import IPython.display as display

COMFYUI_DIR = Path("/notebooks/ComfyUI")
CUSTOM_NODES_DIR = COMFYUI_DIR / "custom_nodes"
MODELS_DIR = COMFYUI_DIR / "models" / "LLM"

HF_TOKEN = os.environ.get("HF_TOKEN")
if not HF_TOKEN:
    raise ValueError("HF_TOKEN が環境変数に設定されていません")

def run(cmd, cwd=None):
    print(f"RUN: {cmd}")
    subprocess.check_call(cmd, shell=True, cwd=cwd)

def clone_or_update(repo_url, target_dir):
    target_dir = Path(target_dir)
    if not target_dir.exists():
        print(f"{target_dir.name} をインストールしています...")
        run(f"git clone {repo_url} {target_dir}")
    else:
        print(f"{target_dir.name} は既に存在するため更新します...")
        run("git pull", cwd=str(target_dir))

def install_requirements_if_exists(target_dir):
    req_file = Path(target_dir) / "requirements.txt"
    if req_file.exists():
        print(f"{target_dir.name} の requirements.txt をインストールしています...")
        run(f"pip install -r {req_file}")

# 1. ComfyUI 本体
if not (COMFYUI_DIR / "main.py").exists():
    if COMFYUI_DIR.exists():
        print("中途半端な ComfyUI ディレクトリを削除しています...")
        run(f"rm -rf {COMFYUI_DIR}")
    print("ComfyUI をダウンロードしています...")
    run(f"git clone https://github.com/comfyanonymous/ComfyUI.git {COMFYUI_DIR}")
else:
    print("ComfyUI を更新しています...")
    run("git pull", cwd=str(COMFYUI_DIR))

CUSTOM_NODES_DIR.mkdir(parents=True, exist_ok=True)

print("ComfyUI の requirements をインストールしています...")
run(f"pip install -r {COMFYUI_DIR / 'requirements.txt'}")

print("cmake / build-essential / llama-cpp-python はコンテナ導入済みのためスキップします。")

# 2. llama-server 確認
if Path("/usr/local/bin/llama-server").exists():
    print("llama-server はコンテナに導入済みのためスキップします。")
else:
    print("llama-server が見つからないためビルドします。")
    run("git clone https://github.com/ggml-org/llama.cpp.git /notebooks/llama.cpp")
    run('cmake -S /notebooks/llama.cpp -B /notebooks/llama.cpp/build -DGGML_CUDA=ON -DCMAKE_CUDA_ARCHITECTURES="80;86" -DCMAKE_BUILD_TYPE=Release')
    run("cmake --build /notebooks/llama.cpp/build -j 2")
    run("ln -sf /notebooks/llama.cpp/build/bin/llama-server /usr/local/bin/llama-server")

# 3. カスタムノード
custom_nodes = {
    "ComfyUI-Prompt-Manager": "https://github.com/FranckyB/ComfyUI-Prompt-Manager.git",
    "ComfyUI-llama-cpp": "https://github.com/lihaoyun6/ComfyUI-llama-cpp.git",
    "ComfyUI-VideoHelperSuite": "https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite.git",
    "ComfyUI-Easy-Use": "https://github.com/yolain/ComfyUI-Easy-Use.git",
    "rgthree-comfy": "https://github.com/rgthree/rgthree-comfy.git",
}

for folder_name, repo_url in custom_nodes.items():
    node_dir = CUSTOM_NODES_DIR / folder_name
    clone_or_update(repo_url, node_dir)

    if folder_name == "ComfyUI-llama-cpp":
        print(f"{folder_name} の requirements.txt はスキップします（llama-cpp-python固定のため）")
    else:
        install_requirements_if_exists(node_dir)

# 4. Hugging Face ログインとモデルDL
MODELS_DIR.mkdir(parents=True, exist_ok=True)

print("huggingface_hub をインストールしています...")
run("pip install -q huggingface_hub")

from huggingface_hub import login, hf_hub_download

print("Hugging Face にログインします...")
login(token=HF_TOKEN)

qwen_model = MODELS_DIR / "Qwen3.5-9B-Q8_0.gguf"
mmproj_model = MODELS_DIR / "mmproj-BF16.gguf"

if not qwen_model.exists():
    print("Qwen3.5-9B-Q8_0.gguf をダウンロードします...")
    hf_hub_download(
        repo_id="unsloth/Qwen3.5-9B-GGUF",
        filename="Qwen3.5-9B-Q8_0.gguf",
        local_dir=str(MODELS_DIR),
    )

if not mmproj_model.exists():
    print("mmproj-BF16.gguf をダウンロードします...")
    hf_hub_download(
        repo_id="unsloth/Qwen3.5-9B-GGUF",
        filename="mmproj-BF16.gguf",
        local_dir=str(MODELS_DIR),
    )

# 5. ComfyUI Manager の security_level 修正
config_path = COMFYUI_DIR / "user" / "__manager" / "config.ini"
config_path.parent.mkdir(parents=True, exist_ok=True)

print("ComfyUI Manager の security_level を weak に設定します...")
if config_path.exists():
    config_text = config_path.read_text(encoding="utf-8")
    if "security_level" in config_text:
        config_text = re.sub(r"security_level\s*=.*", "security_level = weak", config_text)
    else:
        if "[default]" in config_text:
            config_text += "\nsecurity_level = weak\n"
        else:
            config_text += "\n[default]\nsecurity_level = weak\n"
else:
    config_text = "[default]\nsecurity_level = weak\n"

config_path.write_text(config_text, encoding="utf-8")

print("セットアップ完了")
